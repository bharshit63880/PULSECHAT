{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@chat-app/shared": ["../../packages/shared/src/index.ts"],
      "@chat-app/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts", "tailwind.config.ts"]
}
